{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/generate-hagaki-pdf",
      "dest": "src/server/index.ts",
      "methods": ["POST"],
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "src/server/index.ts"
    }
  ],
  "functions": {
    "src/server/index.ts": {
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "src/**"
    }
  }
}
