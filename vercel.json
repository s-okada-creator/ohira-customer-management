{
  "version": 2,
  "builds": [
    {
      "src": "webapp/src/server/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["webapp/src/**", "☆顧客フォルダ/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "webapp/src/server/index.ts"
    }
  ],
  "functions": {
    "webapp/src/server/index.ts": {
      "maxDuration": 30
    }
  }
}
